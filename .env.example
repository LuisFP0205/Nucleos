# Twitch
# Client ID e Secret obtidos em: https://dev.twitch.tv/console
TWITCH_CLIENT_ID=seu_client_id_aqui
TWITCH_CLIENT_SECRET=seu_client_secret_aqui
TWITCH_CHANNEL=nome_do_seu_canal

# YouTube
# API Key obtida em: https://console.cloud.google.com (YouTube Data API v3)
YOUTUBE_API_KEY=sua_api_key_aqui
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
# OAuth 2.0: console.cloud.google.com → Credenciais → Criar ID do cliente OAuth → App Web
# URI de redirecionamento: http://localhost:3000/auth/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kick
# Canal: slug do canal (ex: seucanalkick)
# Client ID/Secret: kick.com/settings/developer (necessário para enviar comandos no chat)
KICK_CHANNEL=nome_do_seu_canal_kick
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Supabase (opcional — login com Google e e-mail/senha)
# Obtenha em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...

# Servidor
PORT=3000
HOST=0.0.0.0

# Nota: o token de usuário da Twitch NAO vai aqui.
# Ele e obtido automaticamente via OAuth ao clicar em
# "Conectar com Twitch" no dashboard (http://localhost:3000).
